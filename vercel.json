{
  "version": 2,
  "routes": [
    {
      "src": "/api/options-flow",
      "dest": "/api/options-flow.py"
    },
    {
      "src": "/api/public-config",
      "dest": "/api/public-config.py"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
