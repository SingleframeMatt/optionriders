# ─────────────────────────────────────────────────────────────────────────────
# Option Riders — Options Bot  |  .env.example
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── IBKR paper trading connection ─────────────────────────────────────────────
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
IBKR_CLIENT_ID=2

# ── Symbols to watch (SPX skipped — European-style cash-settled) ──────────────
OPTIONS_SYMBOLS=SPY,QQQ

# ── Discord webhook for trade alerts & daily summary ─────────────────────────
# Create a webhook in your Discord server: Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_OPTIONS=

# ── Risk parameters ───────────────────────────────────────────────────────────
OPTIONS_MAX_PER_TRADE=200        # Maximum dollars to spend per trade
OPTIONS_DAILY_LOSS_LIMIT=600     # Stop trading for the day if account P&L hits -$600
OPTIONS_DTE_MIN=2                # Minimum days-to-expiry for options
OPTIONS_DTE_MAX=5                # Maximum days-to-expiry for options

# ── Advanced (optional overrides — defaults shown) ────────────────────────────
# MAX_PREMIUM=2.00               # Max option premium per share (skip if higher)
# MAX_POSITIONS=2                # Max simultaneous open positions
# STOP_LOSS_PCT=0.50             # Close position if it loses 50% of entry value
# TAKE_PROFIT_PCT=1.00           # Close position if it gains 100% (2R)

# ── Web dashboard ─────────────────────────────────────────────────────────────
OPTIONS_SERVER_PORT=8126         # Dashboard port (crypto bot uses 8125)
